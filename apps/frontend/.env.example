# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_NAME=NutriScan AI
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_DEVTOOLS=true

# Auth
VITE_AUTH_TOKEN_KEY=nutriscan_token
VITE_AUTH_REFRESH_KEY=nutriscan_refresh

# Analytics (optional)
VITE_ANALYTICS_ID=

# Sentry (optional)
VITE_SENTRY_DSN=
