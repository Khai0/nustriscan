# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
API_PREFIX=/api

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/nutriscan_dev?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_characters_long
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs

# ─── AI Provider (Phase 3) ────────────────────────────────────────────────────
OPENAI_API_KEY=
AI_MODEL=gpt-4-vision-preview

# ─── Demo Account (chỉ dùng cho development) ─────────────────────────────────
# Email:    demo@nutriscan.ai
# Password: Password123

# ─── Phase 3 — Cookies & CSRF ─────────────────────────────────────────────────
COOKIE_SECRET=change_me_cookie_secret_minimum_32_characters
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CSRF_SECRET=change_me_csrf_secret_minimum_32_characters_long

# ─── Phase 3 — Email (SMTP) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=NutriScan AI <noreply@nutriscan.ai>

# ─── Phase 3 — App URLs ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
EMAIL_VERIFY_EXPIRES_MIN=60
PASSWORD_RESET_EXPIRES_MIN=30

# ─── Phase 3 — Account Lockout ───────────────────────────────────────────────
MAX_FAILED_LOGINS=5
LOCKOUT_DURATION_MIN=15

# ─── Phase 5 — Cloudinary ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=nutriscan_foods

# ─── Phase 5 — Google Cloud Vision ───────────────────────────────────────────
GOOGLE_VISION_API_KEY=your_google_vision_api_key
# OR use service account:
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json

# ─── Phase 5 — AI Provider (abstraction layer) ────────────────────────────────
# Options: google_vision | yolov8 | mock
AI_PROVIDER=google_vision
AI_CONFIDENCE_THRESHOLD=0.6
AI_MAX_LABELS=10

# ─── Phase 6 — AI Recommendations ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
