# ============================================================
# NutriScan AI — Docker Compose environment
# Copy to .env and fill in values before `docker compose up`
# ============================================================

# ── Postgres ───────────────────────────────────────────────
POSTGRES_USER=nutriscan
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=nutriscan_ai
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────
REDIS_PORT=6379

# ── Backend ────────────────────────────────────────────────
BACKEND_PORT=8000
JWT_ACCESS_SECRET=change_me_32_chars_minimum_random_string
JWT_REFRESH_SECRET=change_me_32_chars_minimum_random_string
COOKIE_SECRET=change_me_32_chars_minimum_random_string
CSRF_SECRET=change_me_32_chars_minimum_random_string
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# AI provider: mock | google_vision | yolov8
AI_PROVIDER=mock
GOOGLE_VISION_API_KEY=

# Cloudinary (optional — local storage fallback if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI recommendations (optional — rule-based fallback if empty)
ANTHROPIC_API_KEY=

# Email (optional — logs to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=NutriScan AI <noreply@nutriscan.ai>

# Monitoring (optional)
SENTRY_DSN=

# ── Frontend ───────────────────────────────────────────────
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000
